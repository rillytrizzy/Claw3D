# Optional env for `docker compose up`. Copy to `.env` (compose auto-loads it):
#   cp .env.docker.example .env
#
# Routing to the host Hermes adapter is already set in docker-compose.yml;
# these are only needed to enable in-office ElevenLabs voice replies.

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=
